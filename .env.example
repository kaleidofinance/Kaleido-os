# ============================================
# Kaleido Finance - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ============================================
# Contract Addresses (Abstract Testnet)
# ============================================
# Main Diamond contract - EIP-2535 Diamond Standard
NEXT_PUBLIC_KALEIDO_DIAMOND_ADDRESS=0x7286F2708f8f4d0a1a1b6c19f5D14AdB4c3207B2
PRIVATE_KEY=9e5345ca0415a07573d5b63737e0126382daceb88286d6947055b3d49270c139
# Token Faucet contract for claiming test tokens
NEXT_PUBLIC_TOKENFAUCET_ADDRESS=0xC99eddf1f7C9250728A47978732928aE158396E7

# KLD Vault contract for liquid staking
NEXT_PUBLIC_KLD_VAULT_ADDRESS=0xb6fb7fd04eCF2723f8a5659134a145Bd7fE68748

# Protocol contract address
NEXT_PUBLIC_PROTOCOL_ADDRESS=0xBCc9e3d13CeB24C46Aa2BC7521265B3ace4bb410

# Pyth Oracle contract for price feeds
NEXT_PUBLIC_PYTH_ORACLE_ADDRESS=0xCCd51348cD067adD83747AD7082E557257f7C17d

# ============================================
# RPC URLs
# ============================================
# HTTP RPC endpoint (general)
NEXT_PUBLIC_HTTP_RPC=https://api.testnet.abs.xyz

# WebSocket RPC endpoint (for real-time subscriptions)
NEXT_PUBLIC_WEBSOCKET_RPC=wss://api.testnet.abs.xyz

# HTTP RPC for Abstract network specifically
NEXT_PUBLIC_HTTP_RPC_AB=https://api.testnet.abs.xyz

# ============================================
# Third-party Services
# ============================================
# Thirdweb Client ID (for wallet connection)
NEXT_PUBLIC_THIRDWEB_CLIENT_KEY=your_thirdweb_client_id_here

# Supabase URL (for database)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon Key (public API key)
NEXT_PUBLIC_SUPABASE_KEY=your_supabase_anon_key_here

# ============================================
# Twitter/X Authentication
# ============================================
# Twitter OAuth Client ID
NEXT_PUBLIC_TWITTER_CLIENT_ID=your_twitter_client_id_here

# Twitter OAuth Redirect URI
NEXT_PUBLIC_TWITTER_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Twitter API Key
NEXT_PUBLIC_TWITTER_KEY=your_twitter_api_key_here

# ============================================
# Analytics
# ============================================
# Google Analytics Measurement ID (optional)
NEXT_PUBLIC_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================
# Development Only (Optional)
# ============================================
# Private key for local development/testing (NEVER commit real keys)
# NEXT_PUBLIC_PRIVATE_KEY=your_private_key_here

# ============================================
# Notes
# ============================================
# - All NEXT_PUBLIC_* variables are exposed to the browser
# - Never put sensitive keys in NEXT_PUBLIC_* variables
# - For production, use environment-specific values
# - Contract addresses are for Abstract Testnet (Chain ID: 11124)
# - For other networks, update addresses accordingly
